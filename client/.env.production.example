# Production environment for the AzCuts client.
# Vite bakes VITE_* vars at BUILD time, so set these before `npm run build`
# (copy to .env.production, or provide them as env vars in your host's build step).
# Point them at your deployed API + Socket.io origin (HTTPS in production).
VITE_API_URL=https://api.your-domain.com/api
VITE_SOCKET_URL=https://api.your-domain.com
